# Copy to .env and fill in — NEVER commit the real .env (see .gitignore).

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID (gating / allowlist).
# Get it from @userinfobot, or via
#   https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates  -> message.from.id
# Comma-separate multiple IDs if you need to allow more than one.
TELEGRAM_ALLOW_FROM=

# --- Gateway-independent one-way announce (scripts/telegram_notify.py) --------
# OpenClaw is the interactive control plane; these two vars are ONLY for the
# optional, stdlib-only announce that pushes the nightly report to Telegram from
# a host that holds the token but runs NO OpenClaw (Tier-0 / operator / CI /
# Broker). See docs/telegram/standalone-notify.md.
# Destination chat/user id for the announce. Falls back to the first
# TELEGRAM_ALLOW_FROM id when unset (a DM bot's chat id == your user id).
# TELEGRAM_ANNOUNCE_TO=
# Opt-in for the final announce step in scripts/nightly-audit.sh (default off).
# No-op anyway on the credential-free Worker, which never holds the token.
# TELEGRAM_NOTIFY=0

# Writer / tool-provider family (the audit agent + the promptfoo provider path).
ANTHROPIC_API_KEY=

# Independent grader — MUST be a DIFFERENT model family than the writer above
# (writer != checker). The promptfoo config defaults the llm-rubric grader to
# openai:gpt-4o-mini, so provide an OpenAI key here — OR set GRADER_PROVIDER to a
# local model (e.g. ollama:chat:llama3.1) and leave this blank.
OPENAI_API_KEY=
# Override the grader provider (else the config default openai:gpt-4o-mini is used).
# Keep it a different family than the writer. Example for a zero-cloud-key grader:
# GRADER_PROVIDER=ollama:chat:llama3.1

# Fine-grained GitHub PAT: target repo only, contents + pull-requests + issues,
# NO secrets. issues:write is needed for the nightly findings flow (it files the
# schema-drift / red-team tickets).
GITHUB_TOKEN=

# Target MCP server repo, e.g. malkreide/zurich-opendata-mcp
TARGET_REPO=

# --- Phase 5: budget guardrails (scripts/budget_guard.py) ---------------------
# All optional — safe defaults apply if unset. See docs/budget/guardrails.md.
# NOTE: without the TensorZero gateway, the token ceilings count only the
# promptfoo eval's tokens (stats.tokenUsage.total) — NOT the OpenClaw auditor
# agent's own writer/tool-loop spend. For a true end-to-end per-run cost-cap wire
# TENSORZERO_GATEWAY (below); otherwise treat these as an eval-token bound.
# BUDGET_GUARD=1                       # 0/off disables the guard (e.g. first run)
# BUDGET_TOKENS_PER_RUN=200000         # per-run token ceiling (eval tokens unless TensorZero)
# BUDGET_TOKENS_WINDOW=2000000         # rolling-window token ceiling
# BUDGET_WINDOW_SECONDS=86400          # rolling-window length (seconds)
# BUDGET_BREAKER_THRESHOLD=3           # consecutive hard-fails before the breaker opens
# BUDGET_BREAKER_COOLDOWN_SECONDS=21600 # cooldown before a half-open trial run
# BUDGET_MAX_ITERATIONS=25             # agent iteration cap (passed upstream)

# --- Phase 6: improve loop (scripts/improve-loop.sh) — optional ---------------
# Weekly self-improvement of the target's determ suite; see
# docs/plans/2026-07-13-phase-6-improve-loop.md. All optional — safe defaults.
# IMPROVE_MAX_ITER=10                  # writer iterations per run
# IMPROVE_MAX_KEEPS=5                  # keeps ceiling (suite-bloat guard)
# IMPROVE_COVERAGE_MODE=schema-path    # D3: schema-path (lite) | mutation | off
# IMPROVE_MUTANTS_DIR=                 # mutant *.patch pool (mutation mode only)
# IMPROVE_WRITER_MODEL=claude-opus-4-8 # writer model (Anthropic family)
# IMPROVE_ITER_TOKEN_CEILING=          # per-iteration token ceiling (budget guard)
# IMPROVE_PUBLISH=0                    # 1 = push improve/<date> + open draft PR

# --- Phase 5: TensorZero gateway (tensorzero/) — optional --------------------
# Only needed if you run the gateway between OpenClaw and the provider.
# See docs/observability/tensorzero.md.
# CLICKHOUSE_USER=tensorzero
# CLICKHOUSE_PASSWORD=                 # required by tensorzero/docker-compose.yml
# When OpenClaw should call the gateway instead of Anthropic directly:
# ANTHROPIC_BASE_URL=http://127.0.0.1:3000
# Set this to enable per-run episode-tagging + the real per-run token cost-cap
# (nightly-audit.sh sums the run's tokens from ClickHouse via deploy/tensorzero/):
# TENSORZERO_GATEWAY=http://127.0.0.1:3000
# CLICKHOUSE_HTTP=http://127.0.0.1:8123    # used by deploy/tensorzero/episode-tokens.sh
