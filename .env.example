# Copy to .env and fill in — NEVER commit the real .env (see .gitignore).

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID (gating / allowlist).
# Get it from @userinfobot, or via
#   https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates  -> message.from.id
# Comma-separate multiple IDs if you need to allow more than one.
TELEGRAM_ALLOW_FROM=

# Independent grader model (different family than the writer agent)
ANTHROPIC_API_KEY=

# Fine-grained GitHub PAT: target repo only, contents + pull-requests, NO secrets
GITHUB_TOKEN=

# Target MCP server repo, e.g. malkreide/zurich-opendata-mcp
TARGET_REPO=
