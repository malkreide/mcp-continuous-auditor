# Copy to .env and fill in — NEVER commit the real .env (see .gitignore).

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID (gating / allowlist).
# Get it from @userinfobot, or via
#   https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates  -> message.from.id
# Comma-separate multiple IDs if you need to allow more than one.
TELEGRAM_ALLOW_FROM=

# Independent grader model (different family than the writer agent)
ANTHROPIC_API_KEY=

# Fine-grained GitHub PAT: target repo only, contents + pull-requests, NO secrets
GITHUB_TOKEN=

# Target MCP server repo, e.g. malkreide/zurich-opendata-mcp
TARGET_REPO=

# --- Phase 5: budget guardrails (scripts/budget_guard.py) ---------------------
# All optional — safe defaults apply if unset. See docs/budget/guardrails.md.
# BUDGET_GUARD=1                       # 0/off disables the guard (e.g. first run)
# BUDGET_TOKENS_PER_RUN=200000         # per-run token ceiling
# BUDGET_TOKENS_WINDOW=2000000         # rolling-window token ceiling
# BUDGET_WINDOW_SECONDS=86400          # rolling-window length (seconds)
# BUDGET_BREAKER_THRESHOLD=3           # consecutive hard-fails before the breaker opens
# BUDGET_BREAKER_COOLDOWN_SECONDS=21600 # cooldown before a half-open trial run
# BUDGET_MAX_ITERATIONS=25             # agent iteration cap (passed upstream)

# --- Phase 5: TensorZero gateway (tensorzero/) — optional --------------------
# Only needed if you run the gateway between OpenClaw and the provider.
# See docs/observability/tensorzero.md.
# CLICKHOUSE_USER=tensorzero
# CLICKHOUSE_PASSWORD=                 # required by tensorzero/docker-compose.yml
# When OpenClaw should call the gateway instead of Anthropic directly:
# ANTHROPIC_BASE_URL=http://127.0.0.1:3000
