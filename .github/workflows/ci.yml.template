# CI = the deterministic source of truth (Plan Phase 0 + Phase 2).
#
# TEMPLATE for the TARGET MCP-server repo (e.g. zurich-opendata-mcp) — NOT the
# auditor. pytest/mypy/ruff run against the MCP server code, and promptfoo evals
# the server's tools in-process. In the auditor repo there is no src/ to test,
# so this file ships as `.yml.template` and does not execute here.
#
# To activate in the target repo: copy to `.github/workflows/ci.yml`, then mark
# the `verify`, `determ` and `graded` jobs as REQUIRED status checks in branch
# protection on `main`. No deploy, no push to main — humans are the merge gate.
#
# The promptfoo layer is split at the credential boundary (Analysis T-C):
#   * determ — key-less contract + schema-drift + injection. No secrets, so it
#              runs on every PR (incl. forks). This is the deterministic gate.
#   * graded — the model-graded layer (llm-rubric + committed red-team). Needs a
#              grader key; runs the profile the credential-free Worker never does.

name: ci

on:
  pull_request:
  push:
    branches: [main]

permissions:
  contents: read

jobs:
  verify:
    name: ruff + mypy + pytest
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install uv
        uses: astral-sh/setup-uv@v5
      - name: Set up Python
        run: uv python install 3.11
      - name: Sync dependencies
        run: uv sync --all-extras --dev
      - name: Lint
        run: uv run ruff check
      - name: Type-check
        run: uv run mypy .
      - name: Test
        run: uv run pytest

  determ:
    # REQUIRED status check — the KEY-LESS deterministic gate (contract + schema
    # drift + injection). No secrets, so it runs on every PR incl. forks. Mark it
    # required in branch protection so a broken schema / contract stops the PR red
    # (Plan Phase 2: "a PR with a deliberately broken schema is stopped red by CI").
    name: promptfoo determ (contract + schema-drift, key-less)
    runs-on: ubuntu-latest
    needs: verify
    env:
      # Pin the truth-engine — never eval at @latest (a moving deterministic gate).
      PROMPTFOO_VERSION: "0.121.17"
      # Import path of the FastMCP server instance in the target repo.
      MCP_SERVER_IMPORT: zurich_opendata_mcp.server:mcp
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "20"
      - name: Install uv
        uses: astral-sh/setup-uv@v5
      - name: Sync Python deps (FastMCP in-memory client)
        run: uv sync --all-extras --dev
      - name: Schema-drift gate — regenerate from type hints, fail on any diff
        # Deterministic: if a tool's return type (or upstream shape) changed and
        # the committed schemas/ were not regenerated, this exits non-zero.
        run: uv run python schemas/generate_schemas.py --check
      - name: Run promptfoo determ profile (no model key required)
        run: |
          npx -y "promptfoo@${PROMPTFOO_VERSION}" eval \
            -c promptfoo/promptfooconfig.determ.yaml

  graded:
    # REQUIRED status check — the MODEL-GRADED layer (llm-rubric + committed
    # red-team). This is the profile the credential-free Worker never runs; here in
    # CI a scoped grader key is available. Runs on every PR from the base repo.
    name: promptfoo graded (llm-rubric + red-team)
    runs-on: ubuntu-latest
    needs: verify
    env:
      # Writer family (the audited/tool provider path may use Anthropic).
      ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
      # Independent grader — a DIFFERENT model family than the writer agent, so a
      # correlated failure mode cannot pass its own output. The config defaults the
      # llm-rubric grader to a non-Anthropic family; this key backs that default.
      # (Set GRADER_PROVIDER to a local ollama model to run the grader with no
      #  cloud key at all — see promptfoo/promptfooconfig.yaml.)
      OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
      GRADER_PROVIDER: ${{ vars.GRADER_PROVIDER }}
      # Escape hatch for the writer!=grader guard below (leave unset in normal use).
      ALLOW_SAME_FAMILY_GRADER: ${{ vars.ALLOW_SAME_FAMILY_GRADER }}
      PROMPTFOO_VERSION: "0.121.17"
      MCP_SERVER_IMPORT: zurich_opendata_mcp.server:mcp
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "20"
      - name: Install uv
        uses: astral-sh/setup-uv@v5
      - name: Sync Python deps (FastMCP in-memory client)
        run: uv sync --all-extras --dev
      - name: Enforce writer != grader family (independent check)
        # The writer/tool path is Anthropic; a same-family llm-rubric grader shares
        # its blind spots and is not independent. Refuse an Anthropic GRADER_PROVIDER
        # unless deliberately overridden. Unset -> the config's cross-family default.
        run: |
          case "${GRADER_PROVIDER:-}" in
            anthropic:*|anthropic/*|anthropic)
              if [ "${ALLOW_SAME_FAMILY_GRADER:-0}" != "1" ]; then
                echo "::error::GRADER_PROVIDER='${GRADER_PROVIDER}' is same-family as the Anthropic writer — writer != checker. Use a different family or set ALLOW_SAME_FAMILY_GRADER=1."
                exit 1
              fi
              echo "::warning::same-family grader allowed via ALLOW_SAME_FAMILY_GRADER=1 — not an independent check." ;;
          esac
      - name: Run promptfoo graded profile (llm-rubric + committed red-team)
        # Pinned version (never @latest); --grader override keeps writer != checker.
        run: |
          npx -y "promptfoo@${PROMPTFOO_VERSION}" eval \
            -c promptfoo/promptfooconfig.yaml \
            ${GRADER_PROVIDER:+--grader "$GRADER_PROVIDER"}
      - name: Evaluate the generated red-team set (if committed)
        # The generative expansion (promptfoo/redteam/generate.sh) is committed via
        # a reviewed PR; eval it here when present so the expanded cases gate too.
        run: |
          if [ -f promptfoo/redteam/redteam.generated.yaml ]; then
            npx -y "promptfoo@${PROMPTFOO_VERSION}" eval \
              -c promptfoo/redteam/redteam.generated.yaml \
              ${GRADER_PROVIDER:+--grader "$GRADER_PROVIDER"}
          else
            echo "no committed redteam.generated.yaml — skipping (run promptfoo/redteam/generate.sh to add it)"
          fi
