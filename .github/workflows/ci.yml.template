# CI = the deterministic source of truth (Plan Phase 0 + Phase 2).
#
# TEMPLATE for the TARGET MCP-server repo (e.g. zurich-opendata-mcp) — NOT the
# auditor. pytest/mypy/ruff run against the MCP server code, and promptfoo evals
# the server's tools in-process. In the auditor repo there is no src/ to test,
# so this file ships as `.yml.template` and does not execute here.
#
# To activate in the target repo: copy to `.github/workflows/ci.yml`, then mark
# the `verify` and `promptfoo` jobs as REQUIRED status checks in branch
# protection on `main`. No deploy, no push to main — humans are the merge gate.

name: ci

on:
  pull_request:
  push:
    branches: [main]

permissions:
  contents: read

jobs:
  verify:
    name: ruff + mypy + pytest
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install uv
        uses: astral-sh/setup-uv@v5
      - name: Set up Python
        run: uv python install 3.11
      - name: Sync dependencies
        run: uv sync --all-extras --dev
      - name: Lint
        run: uv run ruff check
      - name: Type-check
        run: uv run mypy .
      - name: Test
        run: uv run pytest

  promptfoo:
    # REQUIRED status check. Mark this job ("promptfoo eval (contract + red-team)")
    # as required in branch protection on `main` so a PR cannot merge while the
    # schema-drift gate or any contract/injection assertion is red (Plan Phase 2:
    # "a PR with a deliberately broken schema is stopped red by CI").
    name: promptfoo eval (contract + red-team)
    runs-on: ubuntu-latest
    needs: verify
    env:
      # Writer family (the audited/tool provider path may use Anthropic).
      ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
      # Independent grader — a DIFFERENT model family than the writer agent, so a
      # correlated failure mode cannot pass its own output. The config defaults the
      # llm-rubric grader to a non-Anthropic family; this key backs that default.
      # (Set GRADER_PROVIDER to a local ollama model to run the grader with no
      #  cloud key at all — see promptfoo/promptfooconfig.yaml.)
      OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
      GRADER_PROVIDER: ${{ vars.GRADER_PROVIDER }}
      # Pin the truth-engine — never eval at @latest (a moving deterministic gate).
      PROMPTFOO_VERSION: "0.121.17"
      # Import path of the FastMCP server instance in the target repo.
      MCP_SERVER_IMPORT: zurich_opendata_mcp.server:mcp
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "20"
      - name: Install uv
        uses: astral-sh/setup-uv@v5
      - name: Sync Python deps (FastMCP in-memory client)
        run: uv sync --all-extras --dev
      - name: Schema-drift gate — regenerate from type hints, fail on any diff
        # Deterministic: if a tool's return type (or upstream shape) changed and
        # the committed schemas/ were not regenerated, this exits non-zero.
        run: uv run python schemas/generate_schemas.py --check
      - name: Run promptfoo (contract asserts + injection + red-team)
        # Adjust the config path to wherever you copy promptfoo/ in the target repo.
        # Pinned version (never @latest); --grader override keeps writer != checker.
        run: |
          npx -y "promptfoo@${PROMPTFOO_VERSION}" eval \
            -c promptfoo/promptfooconfig.yaml \
            ${GRADER_PROVIDER:+--grader "$GRADER_PROVIDER"}
