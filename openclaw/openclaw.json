{
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": { "source": "env", "provider": "default", "id": "TELEGRAM_BOT_TOKEN" },
      "allowFrom": ["${TELEGRAM_ALLOW_FROM}"],
      "groups": {
        "*": { "requireMention": true }
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "agents": {
    "defaults": {
      "workspace": "openclaw/workspace",
      "sandbox": { "mode": "all", "scope": "agent" }
    }
  }
}
